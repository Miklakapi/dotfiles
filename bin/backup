#!/usr/bin/env bash

set -e

main() {
    local target="$1"

    if [[ -z "$target" ]]; then
        show_usage
        return 1
    fi

    create_backup "$target"
}

show_usage() {
    echo "Usage: backup <file-or-directory>" >&2
}

create_backup() {
    local target="$1"
    local timestamp=""
    local backup_path=""

    if [[ ! -e "$target" ]]; then
        echo "Target does not exist: $target" >&2
        return 1
    fi

    timestamp="$(date +"%Y-%m-%d-%H-%M-%S")"
    backup_path="${target}.backup-${timestamp}"

    cp -R -- "$target" "$backup_path"

    echo "$backup_path"
}

main "$@"
