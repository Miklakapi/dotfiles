#!/usr/bin/env bash

set -e

target="$1"

show_usage() {
    echo "Usage: backup <file-or-directory>"
}

create_backup() {
    local target="$1"
    local timestamp=""
    local backup_path=""

    if [[ -z "$target" ]]; then
        show_usage
        return 1
    fi

    if [[ ! -e "$target" ]]; then
        echo "Target does not exist: $target"
        return 1
    fi

    timestamp="$(date +"%Y-%m-%d-%H-%M-%S")"
    backup_path="${target}.backup-${timestamp}"

    cp -R "$target" "$backup_path"

    echo "$backup_path"
}

create_backup "$target"
