#!/usr/bin/env bash

set -e

local_init="./.tmux-session"
global_init="$(command -v .tmux-session || true)"

main() {
    if [[ -x "$local_init" ]]; then
        run_local_init
        return
    fi

    if [[ -n "$global_init" && -x "$global_init" ]]; then
        run_global_init
        return
    fi

    show_missing_init_error
    return 1
}

run_local_init() {
    "$local_init"
}

run_global_init() {
    "$global_init"
}

show_missing_init_error() {
    echo "No tmux init script found." >&2
    echo "Create .tmux-session in current directory or add global .tmux-session to PATH." >&2
}

main "$@"
