#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    local port="$1"

    if [[ -z "$port" ]]; then
        show_usage
        return 1
    fi

    require_command lsof
    show_port_info "$port"
}

show_usage() {
    echo "Usage: port-info <port>" >&2
}

show_port_info() {
    local port="$1"

    print_port_info_header
    print_port_info_rows "$port"
}

print_port_info_header() {
    printf "%-8s %-10s %-14s %-14s %s\n" "PORT" "PID" "COMMAND" "ADDRESS" "USER"
}

print_port_info_rows() {
    local port="$1"

    lsof -nP -iTCP:"$port" -sTCP:LISTEN | awk -v port="$port" '
        NR > 1 {
            printf "%-8s %-10s %-14s %-14s %s\n", port, $2, $1, $9, $3
        }
    '
}

main "$@"
