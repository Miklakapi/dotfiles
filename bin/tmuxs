#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
dotfiles_bin="$script_dir/bin"
tmux_session_command="$dotfiles_bin/tmux-session"

source "$script_dir/lib/common.sh"

main() {
    local selected=""
    local selected_name=""
    local target_pane=""

    require_command tmux

    selected="$(get_selected_project "${1:-}")"

    if [[ -z "$selected" ]]; then
        return
    fi

    require_project_dir "$selected"

    selected_name="$(create_session_name "$selected")"

    if has_tmux_session "$selected_name"; then
        switch_to_session "$selected_name"
        return
    fi

    target_pane="$(create_session "$selected_name" "$selected")"
    configure_session_project_env "$selected_name" "$selected"
    run_session_setup "$target_pane" "$selected"
    switch_to_session "$selected_name"
}

get_selected_project() {
    local project_arg="$1"

    if [[ -n "$project_arg" ]]; then
        echo "$project_arg"
        return
    fi

    require_command fzf
    require_projects_config

    select_project || true
}

require_projects_config() {
    if [[ -n "$TMUX_PROJECT_DIRS" || -n "$TMUX_PROJECTS" ]]; then
        return
    fi

    echo "TMUX_PROJECT_DIRS or TMUX_PROJECTS is not set." >&2
    echo "Example:" >&2
    echo 'export TMUX_PROJECT_DIRS="$HOME/Code/personal:$HOME/Code/work"' >&2
    echo 'export TMUX_PROJECTS="$HOME/.config/nvim"' >&2
    return 1
}

select_project() {
    local open_sessions=""
    local selected=""

    open_sessions="$(get_open_sessions)"
    selected="$(
        find_projects "$open_sessions" |
            sort -t $'\t' -k1,1n -k3,3 |
            env FZF_DEFAULT_OPTS= fzf \
                --delimiter=$'\t' \
                --with-nth=2,3 \
                --layout=reverse \
                --header="󰓩 open tmux session | 󰊢 git repo | 󰒓 local .tmux-session | 󰣖 local ./bin"
    )"

    echo "${selected##*$'\t'}"
}

find_projects() {
    local open_sessions="$1"
    local project_dir=""
    local project=""

    if [[ -n "$TMUX_PROJECT_DIRS" ]]; then
        IFS=":" read -ra project_dirs <<<"$TMUX_PROJECT_DIRS"

        for project_dir in "${project_dirs[@]}"; do
            find_projects_in_dir "$project_dir" "$open_sessions"
        done
    fi

    if [[ -n "$TMUX_PROJECTS" ]]; then
        IFS=":" read -ra projects <<<"$TMUX_PROJECTS"

        for project in "${projects[@]}"; do
            format_project_if_valid "$project" "$open_sessions"
        done
    fi
}

find_projects_in_dir() {
    local project_dir="$1"
    local open_sessions="$2"
    local project=""

    if [[ ! -d "$project_dir" ]]; then
        return
    fi

    while IFS= read -r project; do
        if is_tmux_ignored_project "$project"; then
            continue
        fi

        format_project "$project" "$open_sessions"
    done < <(find "$project_dir" -mindepth 1 -maxdepth 1 -type d)
}

format_project_if_valid() {
    local project="$1"
    local open_sessions="$2"

    if [[ ! -d "$project" ]]; then
        return
    fi

    if is_tmux_ignored_project "$project"; then
        return
    fi

    format_project "$project" "$open_sessions"
}

is_tmux_ignored_project() {
    local project="$1"

    [[ -e "$project/.tmux-ignore" ]]
}

format_project() {
    local project="$1"
    local open_sessions="$2"
    local session_name=""
    local session_marker=" "
    local git_marker=" "
    local config_marker=" "
    local bin_marker=" "
    local sort_group="9"

    session_name="$(create_session_name "$project")"

    if is_session_open "$session_name" "$open_sessions"; then
        session_marker="󰓩"
        sort_group="0"
    fi

    if has_git_repo "$project"; then
        git_marker="󰊢"
    fi

    if has_local_session_config "$project"; then
        config_marker="󰒓"
    fi

    if has_local_bin "$project"; then
        bin_marker="󰣖"
    fi

    printf "%s\t%s %s %s %s\t%s\n" "$sort_group" "$session_marker" "$git_marker" "$config_marker" "$bin_marker" "$project"
}

has_git_repo() {
    local project="$1"

    [[ -e "$project/.git" ]]
}

has_local_session_config() {
    local project="$1"

    [[ -x "$project/.tmux-session" ]]
}

has_local_bin() {
    local project="$1"

    [[ -d "$project/bin" ]]
}

get_open_sessions() {
    tmux list-sessions -F '#S' 2>/dev/null || true
}

is_session_open() {
    local session_name="$1"
    local open_sessions="$2"

    echo "$open_sessions" | grep -Fxq "$session_name"
}

require_project_dir() {
    local selected="$1"

    if [[ -d "$selected" ]]; then
        return
    fi

    echo "Project directory does not exist:" >&2
    echo "  $selected" >&2
    return 1
}

create_session_name() {
    local selected="$1"

    basename "$selected" | tr ":,. " "____"
}

has_tmux_session() {
    local session_name="$1"

    tmux has-session -t "=$session_name" 2>/dev/null
}

switch_to_session() {
    local session_name="$1"

    if [[ -z "$TMUX" ]]; then
        tmux attach-session -t "=$session_name"
        return
    fi

    tmux switch-client -t "=$session_name"
}

create_session() {
    local session_name="$1"
    local selected="$2"

    tmux new-session -ds "$session_name" -c "$selected" -P -F "#{pane_id}"
}

configure_session_project_env() {
    local session_name="$1"
    local selected="$2"
    local project_bin="$selected/bin"
    local current_path=""

    current_path="$(get_session_path "$session_name")"
    current_path="$(create_project_clean_path "$project_bin" "$current_path")"

    tmux set-environment -t "$session_name" TMUX_PROJECT_ROOT "$selected"

    if [[ ! -d "$project_bin" ]]; then
        tmux set-environment -u -t "$session_name" TMUX_PROJECT_BIN 2>/dev/null || true
        tmux set-environment -t "$session_name" PATH "$current_path"
        return
    fi

    tmux set-environment -t "$session_name" TMUX_PROJECT_BIN "$project_bin"
    tmux set-environment -t "$session_name" PATH "$(prepend_to_path "$project_bin" "$current_path")"
}

get_session_path() {
    local session_name="$1"
    local current_path=""

    current_path="$(tmux show-environment -t "$session_name" PATH 2>/dev/null | sed 's/^PATH=//' || true)"

    if [[ -n "$current_path" ]]; then
        echo "$current_path"
        return
    fi

    echo "$PATH"
}

create_project_clean_path() {
    local project_bin="$1"
    local current_path="$2"
    local previous_project_bin="${TMUX_PROJECT_BIN:-}"

    if [[ -n "$previous_project_bin" && "$previous_project_bin" != "$dotfiles_bin" ]]; then
        current_path="$(remove_from_path "$previous_project_bin" "$current_path")"
    fi

    if [[ -n "$project_bin" && "$project_bin" != "$dotfiles_bin" ]]; then
        current_path="$(remove_from_path "$project_bin" "$current_path")"
    fi

    echo "$current_path"
}

prepend_to_path() {
    local path_to_add="$1"
    local current_path="$2"

    if [[ -z "$path_to_add" ]]; then
        echo "$current_path"
        return
    fi

    if [[ -z "$current_path" ]]; then
        echo "$path_to_add"
        return
    fi

    case ":$current_path:" in
    *":$path_to_add:"*)
        echo "$current_path"
        return
        ;;
    esac

    echo "$path_to_add:$current_path"
}

remove_from_path() {
    local path_to_remove="$1"
    local current_path="$2"
    local clean_path=""
    local path_part=""

    if [[ -z "$path_to_remove" ]]; then
        echo "$current_path"
        return
    fi

    IFS=":" read -ra path_parts <<<"$current_path"

    for path_part in "${path_parts[@]}"; do
        if [[ "$path_part" == "$path_to_remove" ]]; then
            continue
        fi

        if [[ -z "$clean_path" ]]; then
            clean_path="$path_part"
            continue
        fi

        clean_path="$clean_path:$path_part"
    done

    echo "$clean_path"
}

run_session_setup() {
    local target_pane="$1"
    local selected="$2"
    local project_bin="$selected/bin"
    local clean_path=""
    local final_path=""
    local escaped_selected=""
    local escaped_project_bin=""
    local escaped_final_path=""
    local escaped_tmux_session_command=""

    clean_path="$(create_project_clean_path "$project_bin" "$PATH")"

    printf -v escaped_selected "%q" "$selected"
    printf -v escaped_project_bin "%q" "$project_bin"
    printf -v escaped_tmux_session_command "%q" "$tmux_session_command"

    if [[ -d "$project_bin" ]]; then
        final_path="$(prepend_to_path "$project_bin" "$clean_path")"
        printf -v escaped_final_path "%q" "$final_path"

        tmux send-keys -t "$target_pane" "export TMUX_PROJECT_ROOT=$escaped_selected; export TMUX_PROJECT_BIN=$escaped_project_bin; export PATH=$escaped_final_path; $escaped_tmux_session_command && clear" C-m
        return
    fi

    printf -v escaped_final_path "%q" "$clean_path"

    tmux send-keys -t "$target_pane" "export TMUX_PROJECT_ROOT=$escaped_selected; unset TMUX_PROJECT_BIN; export PATH=$escaped_final_path; $escaped_tmux_session_command && clear" C-m
}

main "$@"
