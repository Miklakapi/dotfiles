#!/usr/bin/env bash

set -e

require_command() {
    if command -v "$1" >/dev/null 2>&1; then
        return
    fi

    echo "Missing required command: $1"
    exit 1
}

require_projects_config() {
    if [[ -n "$TMUX_PROJECT_DIRS" || -n "$TMUX_PROJECTS" ]]; then
        return
    fi

    echo "TMUX_PROJECT_DIRS or TMUX_PROJECTS is not set."
    echo "Example:"
    echo 'export TMUX_PROJECT_DIRS="$HOME/Code/personal:$HOME/Code/work"'
    echo 'export TMUX_PROJECTS="$HOME/.config/nvim"'
    exit 1
}

has_local_session_config() {
    local project="$1"

    [[ -x "$project/.tmux-session" ]]
}

format_project() {
    local project="$1"
    local open_sessions="$2"
    local session_name
    local session_marker=" "
    local config_marker=" "

    session_name="$(create_session_name "$project")"

    if is_session_open "$session_name" "$open_sessions"; then
        session_marker="󰓩"
    fi

    if has_local_session_config "$project"; then
        config_marker="󰒓"
    fi

    printf "%s %s\t%s\n" "$session_marker" "$config_marker" "$project"
}

find_projects() {
    local open_sessions="$1"
    local project_dir
    local project

    if [[ -n "$TMUX_PROJECT_DIRS" ]]; then
        IFS=":" read -ra project_dirs <<< "$TMUX_PROJECT_DIRS"

        for project_dir in "${project_dirs[@]}"; do
            if [[ ! -d "$project_dir" ]]; then
                continue
            fi

            while IFS= read -r project; do
                format_project "$project" "$open_sessions"
            done < <(find "$project_dir" -mindepth 1 -maxdepth 1 -type d)
        done
    fi

    if [[ -n "$TMUX_PROJECTS" ]]; then
        IFS=":" read -ra projects <<< "$TMUX_PROJECTS"

        for project in "${projects[@]}"; do
            if [[ ! -d "$project" ]]; then
                continue
            fi

            format_project "$project" "$open_sessions"
        done
    fi
}

get_open_sessions() {
    tmux list-sessions -F '#S' 2>/dev/null || true
}

is_session_open() {
    local session_name="$1"
    local open_sessions="$2"

    echo "$open_sessions" | grep -Fxq "$session_name"
}

select_project() {
    local open_sessions
    local selected

    open_sessions="$(get_open_sessions)"
    selected="$(find_projects "$open_sessions" | fzf --delimiter='\t' --with-nth=1,2 --header="󰓩 open tmux session | 󰒓 local .tmux-session")"

    echo "${selected#*$'\t'}"
}

create_session_name() {
    local selected="$1"

    basename "$selected" | tr ":,. " "____"
}

switch_to_session() {
    local session_name="$1"

    if [[ -z "$TMUX" ]]; then
        tmux attach-session -t "$session_name"
        return
    fi

    tmux switch-client -t "$session_name"
}

create_session() {
    local session_name="$1"
    local selected="$2"

    tmux new-session -ds "$session_name" -c "$selected"
}

run_session_setup() {
    local session_name="$1"

    tmux send-keys -t "$session_name" "tmux-session && clear" C-m
}

main() {
    local selected
    local selected_name

    require_command tmux
    require_command fzf
    require_projects_config

    selected="$(select_project || true)"

    if [[ -z "$selected" ]]; then
        exit 0
    fi

    selected_name="$(create_session_name "$selected")"

    if tmux has-session -t "$selected_name" 2>/dev/null; then
        switch_to_session "$selected_name"
        return
    fi

    create_session "$selected_name" "$selected"
    run_session_setup "$selected_name"
    switch_to_session "$selected_name"
}

main "$@"
