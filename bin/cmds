#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

global_bin_dir="$script_dir/bin"

main() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        show_usage
        return
    fi

    show_commands
}

show_usage() {
    echo "Usage: cmds"
    echo
    echo "Shows available project and global commands."
    echo
    echo "Project commands are shown first."
    echo "Global commands are shown below them."
    echo
    echo "Hidden files are ignored."
    echo
    echo "Colors:"
    echo "  project commands - green"
    echo "  global commands  - blue"
}

show_commands() {
    local project_bin_dir=""

    project_bin_dir="$(get_project_bin_dir)"

    print_header

    if [[ -n "$project_bin_dir" ]]; then
        print_commands_from_dir "$project_bin_dir" "project"
    fi

    print_commands_from_dir "$global_bin_dir" "global"
}

get_project_bin_dir() {
    if [[ -n "${TMUX_PROJECT_BIN:-}" && -d "$TMUX_PROJECT_BIN" ]]; then
        echo "$TMUX_PROJECT_BIN"
        return
    fi

    if [[ -n "${TMUX_PROJECT_ROOT:-}" && -d "$TMUX_PROJECT_ROOT/bin" ]]; then
        echo "$TMUX_PROJECT_ROOT/bin"
        return
    fi

    if [[ -d "./bin" ]]; then
        cd "./bin" && pwd
        return
    fi
}

print_header() {
    echo "Available commands"
    echo "------------------"
}

print_commands_from_dir() {
    local bin_dir="$1"
    local command_type="$2"
    local command_file=""

    if [[ ! -d "$bin_dir" ]]; then
        return
    fi

    while IFS= read -r command_file; do
        print_command "$command_file" "$command_type"
    done < <(find "$bin_dir" -maxdepth 1 -type f -perm -111 ! -name ".*" | sort)
}

print_command() {
    local command_file="$1"
    local command_type="$2"
    local command_name=""

    command_name="$(basename "$command_file")"

    printf "  "
    print_colored_command "$command_name" "$command_type"
    printf "\n"
}

print_colored_command() {
    local command_name="$1"
    local command_type="$2"

    if ! should_use_color; then
        printf "%s" "$command_name"
        return
    fi

    case "$command_type" in
    project)
        printf "\033[1;32m%s\033[0m" "$command_name"
        ;;

    global)
        printf "\033[1;36m%s\033[0m" "$command_name"
        ;;

    *)
        printf "%s" "$command_name"
        ;;
    esac
}

should_use_color() {
    [[ -t 1 && "${NO_COLOR:-}" == "" ]]
}

main "$@"
