#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    local selected_sessions=""

    require_command tmux
    require_command fzf

    selected_sessions="$(select_sessions || true)"

    if [[ -z "$selected_sessions" ]]; then
        return
    fi

    kill_sessions "$selected_sessions"
}

select_sessions() {
    local open_sessions=""
    local selected_sessions=""

    open_sessions="$(get_open_sessions)"

    if [[ -z "$open_sessions" ]]; then
        echo "No tmux sessions are currently open."
        return
    fi

    selected_sessions="$(
        echo "$open_sessions" |
            fzf \
                --multi \
                --layout=reverse \
                --prompt="Kill tmux sessions > " \
                --header="TAB - select, ENTER - kill selected"
    )"

    echo "$selected_sessions"
}

get_open_sessions() {
    tmux list-sessions -F '#S' 2>/dev/null || true
}

kill_sessions() {
    local selected_sessions="$1"
    local current_session=""
    local other_sessions=""
    local session_name=""

    current_session="$(get_current_session)"

    while IFS= read -r session_name; do
        if [[ -z "$session_name" ]]; then
            continue
        fi

        if [[ -n "$current_session" && "$session_name" == "$current_session" ]]; then
            continue
        fi

        other_sessions+="$session_name"$'\n'
    done <<<"$selected_sessions"

    while IFS= read -r session_name; do
        if [[ -z "$session_name" ]]; then
            continue
        fi

        kill_session "$session_name"
    done <<<"$other_sessions"

    if selected_sessions_include_current_session "$selected_sessions" "$current_session"; then
        kill_session "$current_session"
    fi
}

get_current_session() {
    if [[ -z "${TMUX:-}" ]]; then
        return
    fi

    tmux display-message -p '#S' 2>/dev/null || true
}

selected_sessions_include_current_session() {
    local selected_sessions="$1"
    local current_session="$2"
    local session_name=""

    if [[ -z "$current_session" ]]; then
        return 1
    fi

    while IFS= read -r session_name; do
        if [[ "$session_name" == "$current_session" ]]; then
            return 0
        fi
    done <<<"$selected_sessions"

    return 1
}

kill_session() {
    local session_name="$1"

    run_tmux_close_if_needed "$session_name"

    tmux kill-session -t "$session_name"
    echo "Killed session: $session_name"
}

run_tmux_close_if_needed() {
    local session_name="$1"
    local project_root=""
    local close_script=""

    project_root="$(get_session_project_root "$session_name")"

    if [[ -z "$project_root" ]]; then
        return
    fi

    close_script="$project_root/.mkdev/tmux-close"

    if [[ ! -f "$close_script" ]]; then
        return
    fi

    if [[ ! -x "$close_script" ]]; then
        echo ".mkdev/tmux-close exists but is not executable:" >&2
        echo "  $close_script" >&2
        echo
        echo "Run:" >&2
        echo "  chmod +x .mkdev/tmux-close" >&2
        return 1
    fi

    echo "Running .mkdev/tmux-close for session: $session_name"

    (
        cd "$project_root"
        "$close_script"
    )
}

get_session_project_root() {
    local session_name="$1"
    local project_root=""

    project_root="$(
        tmux show-environment -t "$session_name" TMUX_PROJECT_ROOT 2>/dev/null |
            sed 's/^TMUX_PROJECT_ROOT=//'
    )"

    echo "$project_root"
}

main "$@"
