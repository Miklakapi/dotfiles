#!/usr/bin/env bash

set -e

target_pane="${TMUX_PANE}"
target_window="$(tmux display-message -p -t "$target_pane" "#{window_id}")"

tmux rename-window -t "$target_pane" nvim
tmux send-keys -t "$target_pane" "nvim ." C-m

zsh_pane="$(tmux new-window -n zsh -P -F "#{pane_id}")"
tmux send-keys -t "$zsh_pane" "clear" C-m

if [[ -f package.json ]] && grep -q '"dev"' package.json; then
    dev_pane="$(tmux new-window -n dev -P -F "#{pane_id}")"
    tmux send-keys -t "$dev_pane" "npm run dev" C-m
elif [[ -f go.mod ]]; then
    dev_pane="$(tmux new-window -n dev -P -F "#{pane_id}")"
    tmux send-keys -t "$dev_pane" "clear" C-m
fi

tmux select-window -t "$target_window"
