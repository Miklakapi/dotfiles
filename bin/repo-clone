#!/usr/bin/env bash

set -e

github_api_url="https://api.github.com"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    local query="${1:-}"
    local selected=""
    local repo_name=""
    local repo_url=""
    local clone_dir=""
    local project_dir=""

    if [[ "$query" == "-h" || "$query" == "--help" ]]; then
        show_usage
        return
    fi

    require_dependencies
    require_project_dirs

    if is_git_url "$query"; then
        repo_url="$query"
        repo_name="$(get_repo_name_from_url "$repo_url")"
    else
        require_github_owner

        selected="$(select_repo "$query")"

        if [[ -z "$selected" ]]; then
            return
        fi

        repo_name="$(get_repo_name "$selected")"
        repo_url="$(get_repo_url "$selected")"
    fi

    clone_dir="$(select_clone_dir)"
    prepare_clone_dir "$clone_dir"

    project_dir="$(get_project_dir "$clone_dir" "$repo_name")"

    clone_repo_if_needed "$repo_url" "$project_dir"
    open_project "$project_dir"
}

show_usage() {
    echo "Usage: repo-clone [query|git-url]"
    echo
    echo "Examples:"
    echo "  repo-clone"
    echo "  repo-clone dotfiles"
    echo "  repo-clone api"
    echo "  repo-clone ssh://git@example.com/Kacper/demo-project.git"
    echo "  repo-clone git@github.com:Miklakapi/dotfiles.git"
    echo
    echo "Required config:"
    echo '  export GITHUB_OWNER="Miklakapi"'
    echo '  export TMUX_PROJECT_DIRS="$HOME/Code/personal:$HOME/Code/work"'
}

require_dependencies() {
    require_command curl
    require_command jq
    require_command git
    require_command fzf
    require_command tmuxs
}

require_github_owner() {
    if [[ -n "${GITHUB_OWNER:-}" ]]; then
        return
    fi

    echo "GITHUB_OWNER is not set." >&2
    echo "Example:" >&2
    echo 'export GITHUB_OWNER="Miklakapi"' >&2
    return 1
}

require_project_dirs() {
    if [[ -n "${TMUX_PROJECT_DIRS:-}" ]]; then
        return
    fi

    echo "TMUX_PROJECT_DIRS is not set." >&2
    echo "Example:" >&2
    echo 'export TMUX_PROJECT_DIRS="$HOME/Code/personal:$HOME/Code/work"' >&2
    return 1
}

is_git_url() {
    local value="$1"

    [[ "$value" =~ ^(git@|ssh://|https://|http://).+ ]]
}

select_repo() {
    local query="$1"
    local repos=""

    repos="$(fetch_repos | parse_repos | filter_repos "$query")"

    if [[ -z "$repos" ]]; then
        echo "No repositories found for: $query" >&2
        return 1
    fi

    if has_single_repo "$repos"; then
        echo "$repos"
        return
    fi

    echo "$repos" | fzf \
        --layout=reverse \
        --with-nth=1 \
        --delimiter=$'\t'
}

fetch_repos() {
    curl -fsSL \
        -H "Accept: application/vnd.github+json" \
        "$github_api_url/users/$GITHUB_OWNER/repos?per_page=100&type=owner&sort=updated"
}

parse_repos() {
    jq -r '.[] | select(.name and .ssh_url) | "\(.name)\t\(.ssh_url)"'
}

filter_repos() {
    local query="$1"

    if [[ -z "$query" ]]; then
        cat
        return
    fi

    grep -i "$query" || true
}

has_single_repo() {
    local repos="$1"
    local count=""

    count="$(echo "$repos" | wc -l | tr -d " ")"

    [[ "$count" == "1" ]]
}

get_repo_name() {
    local selected="$1"

    echo "$selected" | cut -f1
}

get_repo_url() {
    local selected="$1"

    echo "$selected" | cut -f2
}

get_repo_name_from_url() {
    local repo_url="$1"
    local repo_name=""

    repo_name="${repo_url%/}"
    repo_name="${repo_name##*/}"
    repo_name="${repo_name##*:}"
    repo_name="${repo_name%.git}"

    echo "$repo_name"
}

select_clone_dir() {
    local project_dirs=()

    IFS=":" read -ra project_dirs <<<"$TMUX_PROJECT_DIRS"

    select_numbered_option \
        "Select clone directory:" \
        "${project_dirs[@]}"
}

prepare_clone_dir() {
    local clone_dir="$1"

    mkdir -p "$clone_dir"
}

get_project_dir() {
    local clone_dir="$1"
    local repo_name="$2"

    echo "$clone_dir/$repo_name"
}

clone_repo_if_needed() {
    local repo_url="$1"
    local project_dir="$2"

    if [[ -d "$project_dir/.git" ]]; then
        echo "Repository already exists:"
        echo "  $project_dir"
        return
    fi

    if [[ -e "$project_dir" ]]; then
        echo "Path already exists, but it is not a git repository:" >&2
        echo "  $project_dir" >&2
        return 1
    fi

    git clone "$repo_url" "$project_dir"
}

open_project() {
    local project_dir="$1"

    tmuxs "$project_dir"
}

main "$@"
