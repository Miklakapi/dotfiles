#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    remove_nvm
    install_fnm
    configure_fnm_shell
    load_fnm
    install_node
}

remove_nvm() {
    remove_nvm_from_shell_configs
    remove_nvm_directory
}

remove_nvm_from_shell_configs() {
    remove_nvm_from_file "$HOME/.bashrc"
    remove_nvm_from_file "$HOME/.bash_profile"
    remove_nvm_from_file "$HOME/.profile"
    remove_nvm_from_file "$HOME/.zshrc"
    remove_nvm_from_file "$HOME/.zprofile"
}

remove_nvm_from_file() {
    local file="$1"
    local temp_file=""

    if [[ ! -f "$file" ]]; then
        return
    fi

    temp_file="$(mktemp)"

    awk '
        $0 ~ /NVM_DIR/ { next }
        $0 ~ /nvm\.sh/ { next }
        $0 ~ /bash_completion/ && $0 ~ /nvm/ { next }
        $0 ~ /\.nvm/ { next }
        { print }
    ' "$file" >"$temp_file"

    cat "$temp_file" >"$file"
    rm -f "$temp_file"
}

remove_nvm_directory() {
    if [[ ! -d "$HOME/.nvm" ]]; then
        return
    fi

    rm -rf "$HOME/.nvm"
}

install_fnm() {
    if command_exists fnm; then
        echo "fnm is already installed"
        fnm --version
        return
    fi

    if command_exists brew; then
        install_package "fnm"
        return
    fi

    if command_exists apt; then
        install_packages curl unzip libatomic1
        curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
    fi
}

configure_fnm_shell() {
    if command_exists apt; then
        append_zsh_block "node" <<'EOF'
export PATH="$HOME/.local/share/fnm:$PATH"

_dotfiles_clean_fnm_path() {
    local clean_path=""
    local path_part=""

    for path_part in "${(@s.:.)PATH}"; do
        case "$path_part" in
            */.local/state/fnm_multishells/*/bin)
                continue
                ;;
        esac

        if [[ -z "$clean_path" ]]; then
            clean_path="$path_part"
            continue
        fi

        clean_path="$clean_path:$path_part"
    done

    export PATH="$clean_path"
}

_dotfiles_clean_fnm_path
eval "$(fnm env --use-on-cd)"
EOF
        return
    fi

    append_zsh_block "node" <<'EOF'
_dotfiles_clean_fnm_path() {
    local clean_path=""
    local path_part=""

    for path_part in "${(@s.:.)PATH}"; do
        case "$path_part" in
            */.local/state/fnm_multishells/*/bin)
                continue
                ;;
        esac

        if [[ -z "$clean_path" ]]; then
            clean_path="$path_part"
            continue
        fi

        clean_path="$clean_path:$path_part"
    done

    export PATH="$clean_path"
}

_dotfiles_clean_fnm_path
eval "$(fnm env --use-on-cd)"
EOF
}

load_fnm() {
    if ! command_exists fnm; then
        export PATH="$HOME/.local/share/fnm:$PATH"
    fi

    if command_exists fnm; then
        eval "$(fnm env --use-on-cd)"
    fi
}

install_node() {
    if ! command_exists fnm; then
        return
    fi

    fnm install --latest
    fnm default latest
}

main
