#!/usr/bin/env bash

set -e

show_unsupported_system_message() {
    echo "Docker installation is supported only on Ubuntu."
    echo
    echo "On macOS, install Docker Desktop manually:"
    echo "https://docs.docker.com/desktop/setup/install/mac-install/"
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

is_macos() {
    [[ "$(uname -s)" == "Darwin" ]]
}

is_ubuntu() {
    [[ -f /etc/os-release ]] && grep -q '^ID=ubuntu$' /etc/os-release
}

run_as_root() {
    if [[ "$(id -u)" -eq 0 ]]; then
        "$@"
        return
    fi

    sudo "$@"
}

start_docker_service() {
    if ! command_exists systemctl; then
        echo "systemctl not found. Skipping docker service start."
        return
    fi

    if ! systemctl is-system-running >/dev/null 2>&1; then
        echo "systemd is not running. Skipping docker service start."
        return
    fi

    run_as_root systemctl enable docker
    run_as_root systemctl start docker
}

install_docker_on_ubuntu() {
    echo "Installing Docker on Ubuntu..."

    run_as_root apt-get update

    run_as_root apt-get remove -y \
        docker.io \
        docker-doc \
        docker-compose \
        docker-compose-v2 \
        podman-docker \
        containerd \
        runc || true

    run_as_root apt-get install -y \
        ca-certificates \
        curl

    run_as_root install -m 0755 -d /etc/apt/keyrings

    run_as_root curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
        -o /etc/apt/keyrings/docker.asc

    run_as_root chmod a+r /etc/apt/keyrings/docker.asc

    echo \
        "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu \
        $(. /etc/os-release && echo "${UBUNTU_CODENAME:-$VERSION_CODENAME}") stable" \
        | run_as_root tee /etc/apt/sources.list.d/docker.list >/dev/null

    run_as_root apt-get update

    run_as_root apt-get install -y \
        docker-ce \
        docker-ce-cli \
        containerd.io \
        docker-buildx-plugin \
        docker-compose-plugin

    start_docker_service

    if ! groups "$USER" | grep -q '\bdocker\b'; then
        run_as_root usermod -aG docker "$USER"

        echo
        echo "User '$USER' was added to docker group."
        echo "Log out and log back in to use docker without sudo."
    fi

    echo
    echo "Docker installed."
    docker --version

    if docker compose version >/dev/null 2>&1; then
        docker compose version
    fi
}

if command_exists docker; then
    echo "Docker is already installed:"
    docker --version

    if docker compose version >/dev/null 2>&1; then
        docker compose version
    fi

    exit 0
fi

if is_macos; then
    show_unsupported_system_message
    exit 0
fi

if is_ubuntu; then
    install_docker_on_ubuntu
    exit 0
fi

show_unsupported_system_message
exit 1
