#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tmux_config_source="$script_dir/resources/tmux.conf"
tmux_config_dir="$HOME/.config/tmux"
tmux_config_target="$tmux_config_dir/tmux.conf"

source "$script_dir/lib/common.sh"

main() {
    install_tmux
    install_clipboard_dependencies
    copy_tmux_config
    configure_tmux_projects
}

install_tmux() {
    if command_exists tmux; then
        echo "tmux is already installed"
        tmux -V
        return
    fi

    if command_exists apt; then
        install_packages tmux xclip
        return
    fi

    install_package "tmux"
}

install_clipboard_dependencies() {
    if command_exists pbcopy; then
        return
    fi

    if command_exists xclip; then
        return
    fi

    if command_exists apt; then
        install_package "xclip"
        return
    fi

    echo "Clipboard integration dependency is missing."
    echo "On macOS, pbcopy should be available by default."
    echo "On Debian/Ubuntu, install xclip."
}

copy_tmux_config() {
    mkdir -p "$tmux_config_dir"

    if [[ ! -f "$tmux_config_source" ]]; then
        echo "tmux config source does not exist: $tmux_config_source"
        return 1
    fi

    if [[ ! -f "$tmux_config_target" ]]; then
        cp "$tmux_config_source" "$tmux_config_target"
        echo "tmux config copied:"
        echo "$tmux_config_target"
        return
    fi

    echo "tmux config already exists:"
    echo "$tmux_config_target"

    if ask_yes_no "Overwrite it? [y/N] "; then
        cp "$tmux_config_source" "$tmux_config_target"
        echo "tmux config overwritten:"
        echo "$tmux_config_target"
        return
    fi

    echo "Existing tmux config was not changed."
}

configure_tmux_projects() {
    local project_dirs=""
    local projects=""

    if has_zsh_block "tmux"; then
        echo "tmux is already configured"
        return
    fi

    echo "Enter project directories separated by colon:"
    echo 'Example: $HOME/Code/personal:$HOME/Code/work'
    read -r -p "TMUX_PROJECT_DIRS: " project_dirs

    echo "Enter single projects separated by colon:"
    echo 'Example: $HOME/.config/nvim:$HOME/.config/tmux'
    read -r -p "TMUX_PROJECTS: " projects

    if [[ -z "$project_dirs" && -z "$projects" ]]; then
        echo "No project config provided. Skipping."
        return
    fi

    append_zsh_block "tmux" <<EOF
export TMUX_PROJECT_DIRS="$project_dirs"
export TMUX_PROJECTS="$projects"

if [[ -n "\$TMUX" && -n "\$TMUX_PROJECT_BIN" && -d "\$TMUX_PROJECT_BIN" ]]; then
    case ":\$PATH:" in
        *":\$TMUX_PROJECT_BIN:"*) ;;
        *) export PATH="\$TMUX_PROJECT_BIN:\$PATH" ;;
    esac
fi
EOF

    echo "tmux projects config saved to $HOME/.zshrc"
    echo "Restart your shell or run:"
    echo "source $HOME/.zshrc"
}

main "$@"
