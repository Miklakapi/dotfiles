#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

go_version="1.26.3"

main() {
    install_go
    configure_go_shell
    load_go
    show_go_version
}

install_go() {
    if command_exists go; then
        echo "go is already installed"
        go version
        return
    fi

    if is_macos; then
        install_package "go"
        return
    fi

    install_go_ubuntu
}

install_go_ubuntu() {
    local arch=""
    local go_tarball=""
    local go_url=""

    if ! command_exists apt; then
        return
    fi

    arch="$(get_go_linux_arch)"

    if [[ -z "$arch" ]]; then
        return
    fi

    go_tarball="go${go_version}.linux-${arch}.tar.gz"
    go_url="https://go.dev/dl/${go_tarball}"

    install_packages curl tar

    curl -fsSL "$go_url" -o "/tmp/$go_tarball"

    sudo rm -rf /usr/local/go
    sudo tar -C /usr/local -xzf "/tmp/$go_tarball"
}

get_go_linux_arch() {
    local arch=""

    arch="$(uname -m)"

    if [[ "$arch" == "x86_64" ]]; then
        echo "amd64"
        return
    fi

    if [[ "$arch" == "aarch64" ]] || [[ "$arch" == "arm64" ]]; then
        echo "arm64"
        return
    fi
}

configure_go_shell() {
    append_zsh_block "go" <<'EOF'
export PATH="/usr/local/go/bin:$HOME/go/bin:$PATH"
EOF
}

load_go() {
    export PATH="/usr/local/go/bin:$HOME/go/bin:$PATH"
}

show_go_version() {
    if command_exists go; then
        go version
    fi
}

main
