#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    install_uv
    load_uv
    install_python
    configure_uv_shell
}

install_uv() {
    if command_exists uv; then
        echo "uv is already installed"
        uv --version
        return
    fi

    if ! command_exists curl; then
        install_package "curl"
    fi

    curl -LsSf https://astral.sh/uv/install.sh | sh
}

load_uv() {
    export PATH="$HOME/.local/bin:$PATH"
}

install_python() {
    if ! command_exists uv; then
        return
    fi

    uv python install
}

configure_uv_shell() {
    remove_uv_shell_lines

    append_zsh_block "python" <<'EOF'
[ -f "$HOME/.local/bin/env" ] && source "$HOME/.local/bin/env"
EOF
}

remove_uv_shell_lines() {
    remove_zsh_line '. "$HOME/.local/bin/env"'
    remove_zsh_line 'source "$HOME/.local/bin/env"'
}

main
