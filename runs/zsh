#!/usr/bin/env bash

set -e

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

is_macos() {
    [[ "$(uname -s)" == "Darwin" ]]
}

install_zsh() {
    if command_exists zsh; then
        echo "zsh is already installed"
        zsh --version
        return
    fi

    if command_exists apt; then
        sudo apt install -y zsh
    fi
}

set_default_shell() {
    local zsh_path

    if is_macos; then
        return
    fi

    if ! command_exists zsh; then
        return
    fi

    zsh_path="$(command -v zsh)"

    if [[ "$SHELL" == "$zsh_path" ]]; then
        echo "zsh is already the default shell"
        return
    fi

    if [[ -f /etc/shells ]] && ! grep -q "^$zsh_path$" /etc/shells; then
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi

    chsh -s "$zsh_path"
}

configure_zsh_prompt() {
    local zshrc="$HOME/.zshrc"

    touch "$zshrc"

    if grep -q "PROMPT='%F{green}%n@%m%f %F{blue}%~%f %# '" "$zshrc"; then
        echo "zsh prompt is already configured"
        return
    fi

    {
        echo ""
        echo "autoload -Uz colors && colors"
        echo "PROMPT='%F{green}%n@%m%f %F{blue}%~%f %# '"
    } >> "$zshrc"
}

install_zsh
set_default_shell
configure_zsh_prompt
