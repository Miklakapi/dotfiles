#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    install_zsh
    set_default_shell
    configure_zsh_prompt
    configure_zsh_colors
    configure_zsh_completion
    configure_zsh_utilities
    configure_zsh_suffix_aliases
}

install_zsh() {
    if command_exists zsh; then
        echo "zsh is already installed"
        zsh --version
        return
    fi

    install_package "zsh"
}

set_default_shell() {
    local zsh_path=""

    if is_macos; then
        return
    fi

    if ! command_exists zsh; then
        return
    fi

    zsh_path="$(command -v zsh)"

    if [[ "$SHELL" == "$zsh_path" ]]; then
        echo "zsh is already the default shell"
        return
    fi

    if [[ -f /etc/shells ]] && ! grep -q "^$zsh_path$" /etc/shells; then
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi

    chsh -s "$zsh_path"
}

configure_zsh_prompt() {
    append_zsh_block "zsh prompt" <<'EOF'
autoload -Uz colors && colors
PROMPT='%F{green}%n@%m%f %F{blue}%~%f %# '
EOF
}

configure_zsh_colors() {
    append_zsh_block "zsh colors" <<'EOF'
if [[ "$(uname -s)" == "Darwin" ]]; then
    export CLICOLOR=1
    alias ls='ls -G'
else
    if [[ -x /usr/bin/dircolors ]]; then
        [[ -r ~/.dircolors ]] && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    fi

    alias ls='ls --color=auto'
fi

alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
EOF
}

configure_zsh_completion() {
    append_zsh_block "zsh completion" <<'EOF'
autoload -Uz compinit
compinit

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
EOF
}

configure_zsh_utilities() {
    append_zsh_block "zsh utilities" <<'EOF'
autoload -Uz zmv
EOF
}

configure_zsh_suffix_aliases() {
    append_zsh_block "zsh suffix aliases" <<'EOF'
_dotfiles_bat_json() {
    local file="$1"

    jq . "$file" | bat --language json --file-name "$file"
}

alias -s c='nvim'
alias -s cc='nvim'
alias -s cpp='nvim'
alias -s cs='nvim'
alias -s css='nvim'
alias -s go='nvim'
alias -s h='nvim'
alias -s hpp='nvim'
alias -s java='nvim'
alias -s js='nvim'
alias -s jsx='nvim'
alias -s kt='nvim'
alias -s lua='nvim'
alias -s php='nvim'
alias -s py='nvim'
alias -s rb='nvim'
alias -s rs='nvim'
alias -s scss='nvim'
alias -s sh='nvim'
alias -s sql='nvim'
alias -s ts='nvim'
alias -s tsx='nvim'
alias -s zsh='nvim'

alias -s conf='bat'
alias -s config='bat'
alias -s csv='bat'
alias -s env='bat'
alias -s gitignore='bat'
alias -s ini='bat'
alias -s lock='bat'
alias -s log='bat'
alias -s md='bat'
alias -s toml='bat'
alias -s tsv='bat'
alias -s txt='bat'
alias -s xml='bat'
alias -s yaml='bat'
alias -s yml='bat'

alias -s json='_dotfiles_bat_json'

alias -s htm='serve'
alias -s html='serve'
EOF
}

main
