#!/usr/bin/env bash

set -e

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

install_fnm() {
    if command_exists fnm; then
        echo "fnm is already installed"
        fnm --version
        return
    fi

    if command_exists brew; then
        brew install fnm
        return
    fi

    if command_exists apt; then
        sudo apt update
        sudo apt install -y curl unzip libatomic1
        curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
    fi
}

configure_fnm_shell() {
    local zshrc="$HOME/.zshrc"
    local env_line='eval "$(fnm env --use-on-cd)"'
    local linux_path_line='export PATH="$HOME/.local/share/fnm:$PATH"'

    touch "$zshrc"

    if command_exists apt && ! grep -Fxq "$linux_path_line" "$zshrc"; then
        echo "$linux_path_line" >> "$zshrc"
    fi

    if ! grep -Fxq "$env_line" "$zshrc"; then
        echo "$env_line" >> "$zshrc"
    fi
}

load_fnm() {
    if ! command_exists fnm; then
        export PATH="$HOME/.local/share/fnm:$PATH"
    fi

    if command_exists fnm; then
        eval "$(fnm env --use-on-cd)"
    fi
}

install_node() {
    if ! command_exists fnm; then
        return
    fi

    fnm install --latest
    fnm default latest
}

install_fnm
configure_fnm_shell
load_fnm
install_node
