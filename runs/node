#!/usr/bin/env bash

set -e

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

remove_nvm_from_file() {
    local file="$1"
    local temp_file=""

    if [[ ! -f "$file" ]]; then
        return
    fi

    temp_file="$(mktemp)"

    awk '
        $0 ~ /NVM_DIR/ { next }
        $0 ~ /nvm\.sh/ { next }
        $0 ~ /bash_completion/ && $0 ~ /nvm/ { next }
        $0 ~ /\.nvm/ { next }
        { print }
    ' "$file" > "$temp_file"

    cat "$temp_file" > "$file"
    rm -f "$temp_file"
}

remove_nvm_from_shell_configs() {
    remove_nvm_from_file "$HOME/.bashrc"
    remove_nvm_from_file "$HOME/.bash_profile"
    remove_nvm_from_file "$HOME/.profile"
    remove_nvm_from_file "$HOME/.zshrc"
    remove_nvm_from_file "$HOME/.zprofile"
}

remove_nvm_directory() {
    if [[ ! -d "$HOME/.nvm" ]]; then
        return
    fi

    rm -rf "$HOME/.nvm"
}

remove_nvm() {
    remove_nvm_from_shell_configs
    remove_nvm_directory
}

install_fnm() {
    if command_exists fnm; then
        echo "fnm is already installed"
        fnm --version
        return
    fi

    if command_exists brew; then
        brew install fnm
        return
    fi

    if command_exists apt; then
        sudo apt update
        sudo apt install -y curl unzip libatomic1
        curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
    fi
}

configure_fnm_shell() {
    local zshrc="$HOME/.zshrc"
    local env_line='eval "$(fnm env --use-on-cd)"'
    local linux_path_line='export PATH="$HOME/.local/share/fnm:$PATH"'

    touch "$zshrc"

    if command_exists apt && ! grep -Fxq "$linux_path_line" "$zshrc"; then
        echo "$linux_path_line" >> "$zshrc"
    fi

    if ! grep -Fxq "$env_line" "$zshrc"; then
        echo "$env_line" >> "$zshrc"
    fi
}

load_fnm() {
    if ! command_exists fnm; then
        export PATH="$HOME/.local/share/fnm:$PATH"
    fi

    if command_exists fnm; then
        eval "$(fnm env --use-on-cd)"
    fi
}

install_node() {
    if ! command_exists fnm; then
        return
    fi

    fnm install --latest
    fnm default latest
}

remove_nvm
install_fnm
configure_fnm_shell
load_fnm
install_node
