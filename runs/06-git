#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    install_git
    configure_git
    configure_repo_clone
}

install_git() {
    if command_exists git; then
        echo "git is already installed"
        git --version
        return
    fi

    install_package "git"
}

configure_git() {
    if ! command_exists git; then
        return
    fi

    configure_git_defaults

    ask_git_config "user.name" "Git user name"
    ask_git_config "user.email" "Git user email"
}

configure_git_defaults() {
    git config --global pull.rebase true
    git config --global rebase.autoStash true
    git config --global fetch.prune true
    git config --global init.defaultBranch main
    git config --global push.autoSetupRemote true
    git config --global diff.algorithm histogram

    echo "git defaults configured"
}

ask_git_config() {
    local key="$1"
    local label="$2"
    local current_value=""
    local new_value=""

    current_value="$(git config --global --get "$key" || true)"

    if [[ -n "$current_value" ]]; then
        echo "$key is already set to: $current_value"
        return
    fi

    read -r -p "$label: " new_value

    if [[ -z "$new_value" ]]; then
        return
    fi

    git config --global "$key" "$new_value"
}

configure_repo_clone() {
    local github_owner="${GITHUB_OWNER:-}"
    local new_github_owner=""

    if ! ask_yes_no "Configure repo-clone? [y/N] "; then
        echo "repo-clone config was not changed."
        return
    fi

    if [[ -n "$github_owner" ]]; then
        echo "Current GitHub username: $github_owner"
    fi

    echo "Enter GitHub username used by repo-clone:"
    echo "Leave empty to keep the current value."
    read -r -p "GITHUB_OWNER: " new_github_owner

    if [[ -n "$new_github_owner" ]]; then
        github_owner="$new_github_owner"
    fi

    if [[ -z "$github_owner" ]]; then
        echo "GITHUB_OWNER was not provided."
        echo "Skipping."
        return
    fi

    append_zsh_block "git" <<EOF
export GITHUB_OWNER="$github_owner"
EOF

    echo "git zsh config saved to $HOME/.zshrc"
    echo "Restart your shell or run:"
    echo "source $HOME/.zshrc"
}

main "$@"
