#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$script_dir/lib/common.sh"

main() {
    install_git
    configure_git
    configure_repo_clone
}

install_git() {
    if command_exists git; then
        echo "git is already installed"
        git --version
        return
    fi

    install_package "git"
}

configure_git() {
    if ! command_exists git; then
        return
    fi

    git config --global pull.rebase true

    ask_git_config "user.name" "Git user name"
    ask_git_config "user.email" "Git user email"
}

ask_git_config() {
    local key="$1"
    local label="$2"
    local current_value=""
    local new_value=""

    current_value="$(git config --global --get "$key" || true)"

    if [[ -n "$current_value" ]]; then
        echo "$key is already set to: $current_value"
        return
    fi

    read -r -p "$label: " new_value

    if [[ -z "$new_value" ]]; then
        return
    fi

    git config --global "$key" "$new_value"
}

configure_repo_clone() {
    local answer=""
    local github_owner=""
    local repo_clone_dir=""

    if has_zsh_block "git"; then
        echo "git zsh config is already configured"
        return
    fi

    read -r -p "Configure repo-clone? [y/N] " answer

    case "$answer" in
        y|Y|yes|YES) ;;
        *)
            echo "repo-clone config was not changed."
            return
            ;;
    esac

    echo "Enter GitHub username used by repo-clone:"
    echo "Example: Miklakapi"
    read -r -p "GITHUB_OWNER: " github_owner

    echo "Enter directory where repo-clone should clone repositories:"
    echo 'Example: $HOME/Code/personal'
    read -r -p "REPO_CLONE_DIR: " repo_clone_dir

    if [[ -z "$github_owner" && -z "$repo_clone_dir" ]]; then
        echo "No repo-clone config provided."
        echo "Skipping."
        return
    fi

    append_zsh_block "git" <<EOF
export GITHUB_OWNER="$github_owner"
export REPO_CLONE_DIR="$repo_clone_dir"
EOF

    echo "git zsh config saved to $HOME/.zshrc"
    echo "Restart your shell or run:"
    echo "source $HOME/.zshrc"
}

main
